<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent: LIVE sentinel fast pass every 1 minute. Checks fractional/synthetic stops
  against fresh public quotes and fires protective sells on breach. NO LLM.
  Pairs with com.agentic.trading-live.plist (10-min planner).

  Install:  cp scripts/com.agentic.live-sentinel.plist ~/Library/LaunchAgents/
            launchctl unload -w ~/Library/LaunchAgents/com.agentic.live-sentinel.plist 2>/dev/null
            launchctl load   -w ~/Library/LaunchAgents/com.agentic.live-sentinel.plist
  Stop:     launchctl unload -w ~/Library/LaunchAgents/com.agentic.live-sentinel.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentic.live-sentinel</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/ABSOLUTE/PATH/TO/agentic-trading/scripts/run_live_sentinel.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading</string>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading/data/logs/live-sentinel.out</string>
    <key>StandardErrorPath</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading/data/logs/live-sentinel.err</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
