<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent: PAPER market-open DD burst. Fires the whole morning slate at once (pool of
  OPEN_SWEEP_CONCURRENCY background DDs) instead of ~5/tick, so all ~40 movers are evaluated within
  minutes of the open. Dispatch-only — no orders. The next normal paper tick ingests + acts.

  Scheduled DUMBLY on StartInterval (every 5 min): the script self-gates to the ET open window and
  runs at most once per trading day (open_dd_sweep.py --gate-only short-circuits the rest of the day
  with no network), so the fixed interval is TZ-robust and doesn't need a calendar trigger. Pairs
  with com.agentic.trading-paper.plist (the 15-min tick that ingests the sweep's verdicts).

  Install:  cp scripts/com.agentic.open-sweep-paper.plist ~/Library/LaunchAgents/
            launchctl unload -w ~/Library/LaunchAgents/com.agentic.open-sweep-paper.plist 2>/dev/null
            launchctl load   -w ~/Library/LaunchAgents/com.agentic.open-sweep-paper.plist
  Stop:     launchctl unload -w ~/Library/LaunchAgents/com.agentic.open-sweep-paper.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentic.open-sweep-paper</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/ABSOLUTE/PATH/TO/agentic-trading/scripts/run_paper_open_sweep.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading</string>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading/data/logs/paper-open-sweep.out</string>
    <key>StandardErrorPath</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading/data/logs/paper-open-sweep.err</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
