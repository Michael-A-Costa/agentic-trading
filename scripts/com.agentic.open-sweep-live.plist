<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent: LIVE market-open DD burst. Fires the whole morning slate at once (pool of
  OPEN_SWEEP_CONCURRENCY background DDs) instead of ~5/tick, so all movers are evaluated within
  minutes of the open. DISPATCH-ONLY — places no orders; a finished COMMIT force-triggers a normal
  LIVE tick (run_live_tick.sh) that ingests + acts under the full caps + LIVE_ARMED gate. Pairs with
  com.agentic.trading-live.plist (the scheduled tick) and com.agentic.live-sentinel.plist.

  Scheduled DUMBLY on StartInterval (every 5 min): the script self-gates to the ET open window and
  runs at most once per trading day (open_dd_sweep.py --gate-only short-circuits the rest of the day
  with no network), so the fixed interval is TZ-robust and needs no calendar trigger.

  Install:  cp scripts/com.agentic.open-sweep-live.plist ~/Library/LaunchAgents/
            launchctl unload -w ~/Library/LaunchAgents/com.agentic.open-sweep-live.plist 2>/dev/null
            launchctl load   -w ~/Library/LaunchAgents/com.agentic.open-sweep-live.plist
  Stop:     launchctl unload -w ~/Library/LaunchAgents/com.agentic.open-sweep-live.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentic.open-sweep-live</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/mcosta/agentic-trading/scripts/run_live_open_sweep.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/mcosta/agentic-trading</string>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/mcosta/agentic-trading/data/logs/live-open-sweep.out</string>
    <key>StandardErrorPath</key>
    <string>/Users/mcosta/agentic-trading/data/logs/live-open-sweep.err</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
