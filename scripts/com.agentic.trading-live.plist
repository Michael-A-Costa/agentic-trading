<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent: LIVE planner tick every 5 minutes. PLACES REAL ORDERS when LIVE_ARMED=1.
  Pairs with com.agentic.live-sentinel.plist (1-min fast loop).

  Kill switches (in order of preference):
    1. launchctl unload com.agentic.trading-live.plist  — stops this scheduler
    2. Set LIVE_ARMED=0 in .env                         — arms nothing new (dry-run)
    3. Disconnect the Robinhood MCP                     — blocks all relay calls

  Install:  cp scripts/com.agentic.trading-live.plist ~/Library/LaunchAgents/
            launchctl unload -w ~/Library/LaunchAgents/com.agentic.trading-live.plist 2>/dev/null
            launchctl load   -w ~/Library/LaunchAgents/com.agentic.trading-live.plist
  Stop:     launchctl unload -w ~/Library/LaunchAgents/com.agentic.trading-live.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentic.trading-live</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/ABSOLUTE/PATH/TO/agentic-trading/scripts/run_live_tick.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading</string>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading/data/logs/live-tick.out</string>
    <key>StandardErrorPath</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading/data/logs/live-tick.err</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
