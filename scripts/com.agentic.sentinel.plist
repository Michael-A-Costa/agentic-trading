<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent: the FAST sentinel pass every 1 minute (StartInterval 60), the fast half of the
  two-rate control loop (docs/two-rate-architecture.md). Deterministic protective exits +
  armed-entry triggers, NO LLM. Pairs with com.agentic.trading-tick.plist (the 5-min planner).

  Both jobs share data/.tick.lock, so they never race on paper_state.json — a sentinel pass that
  collides with a running planner tick simply skips that minute. Off-hours / stale-quote passes are
  silent no-ops (the sentinel only acts on a fresh regular-hours quote).

  Install:  cp scripts/com.agentic.sentinel.plist ~/Library/LaunchAgents/
            launchctl unload -w ~/Library/LaunchAgents/com.agentic.sentinel.plist 2>/dev/null
            launchctl load   -w ~/Library/LaunchAgents/com.agentic.sentinel.plist
  Stop:     launchctl unload -w ~/Library/LaunchAgents/com.agentic.sentinel.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentic.sentinel</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/ABSOLUTE/PATH/TO/agentic-trading/scripts/run_sentinel.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading</string>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading/data/logs/sentinel.out</string>
    <key>StandardErrorPath</key>
    <string>/ABSOLUTE/PATH/TO/agentic-trading/data/logs/sentinel.err</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
