# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Account ---
AGENTIC_ACCOUNT=your_account_number      # the only agentic_allowed account; trade nothing else

# --- Execution mode ---
# paper = simulate against live quotes, place nothing (apply_decision.py).
# live  = real orders via the MCP relay (live_execute.py): marketable-limit entries +
#         resting stop-market exits, no per-trade approval — the .env caps + review +
#         dry-run gate are the seatbelt.
TRADING_MODE=paper
# Two-step arming so live can't fire by accident. With TRADING_MODE=live but LIVE_ARMED!=1
# the engine does everything INCLUDING review_equity_order (real broker quotes/alerts) but
# only LOGS the orders it would place — a true dry-run. Set LIVE_ARMED=1 to actually place.
# Every entry, including the first armed one, is sized to MAX_POSITION_USD like any other.
LIVE_ARMED=0
CASH_SETTLEMENT_GUARD=1        # CASH account: size entries against SETTLED cash only (broker bp
                               #   minus unsettled T+1 sale proceeds and pending deposits) -> no
                               #   Good-Faith Violation from redeploying unsettled funds. 0 = margin.

# --- Risk guardrails (the real safety layer; tune for the funded balance) ---
# Caps are a FRACTION OF LIVE EQUITY — tick_context.py resolves them to $ each tick, so they
# auto-scale as the account compounds or draws down. Sizing + per-trade loss use LIVE equity;
# the daily breaker uses START-OF-DAY equity and is capped at an absolute $/day.
# CATALYST-DRIFT v1: risky sleeve -> concentrated, larger bets. See strategies/catalyst-drift-v1-plan.md.
MAX_POSITION_PCT=0.15          # per-name ceiling = 15% of equity. Whole-share-only means this cap
                               #   must cover at least 1 share of the target name; names priced above
                               #   MAX_POSITION_USD are auto-filtered before DD. Conviction scaling
                               #   (high=1.0, medium=0.6, low=0.35) keeps most entries below the ceiling.
MAX_TOTAL_EXPOSURE_PCT=0.90    # up to 90% invested — a risky directional book runs hot.
MAX_OPEN_POSITIONS=30          # up to 30 slots. Exposure cap (90%) binds first at ~6 full-size
                               #   positions; lower-conviction entries are smaller so more names fit.
MIN_POSITION_USD=0             # reject fills smaller than this (0 = no floor; live's real dust guard is
                               #   the whole-share-only rule in live_execute.size_entry: >=1 share or skip)

# --- LIVE execution knobs (only matter when TRADING_MODE=live) ---
MAX_ENTRIES_PER_TICK=5         # cap entries that reach the broker per tick; rest defer to next tick
# Order relays (sells + entries) are independent I/O-bound `claude` subprocesses; running them
# concurrently means a multi-order tick takes ~one relay instead of the SUM of each ~30-50s relay.
# No token cost — each relay is its own call; only wall-clock shrinks. (Older names
# LIVE_PARALLEL_ENTRIES / LIVE_ENTRY_WORKERS still work as fallbacks.)
LIVE_PARALLEL_ORDERS=1         # run this tick's order relays (sells + entries) concurrently (0 = serial)
LIVE_ORDER_WORKERS=5           # max concurrent order-relay subprocesses
RH_EXEC_TIMEOUT_S=90           # per-relay wall-clock cap
RH_SNAPSHOT_TIMEOUT_S=180      # snapshot relay is heavier (4 tools) -> separate longer cap
RH_SNAPSHOT_RETRIES=2          # snapshot attempts before failing closed (one transient null-portfolio retry)
RH_SNAPSHOT_RETRY_BACKOFF_S=5  # wait between snapshot retries
# Direct Python→MCP fast path for ALL relays (rh_direct.py): reads (snapshot, quotes, recent_orders,
# review) AND writes (place, cancel). Speaks the RH MCP over HTTP using the OAuth token Claude Code keeps
# in the macOS keychain — ~0.3s / $0 / deterministic vs the ~25-56s, ~95-500k-tok haiku agent relay each.
# On any failure (token expired, 401, network, tool error) it falls back to the agent relay, which
# refreshes the keychain token, so the next call is fast again. The LLM was only ever a mechanical relay
# (Python decides sizing/caps/blocking), so calling the tool directly is strictly safer — no model that
# can refuse a place or echo unparseable prose. Writes are safe to retry because the order's ref_id is
# the idempotency key: a relay-fallback re-send with the SAME id is deduped by the broker (no double-place).
# Set 0 to force the relay for everything (kill switch covers writes too).
RH_DIRECT_MCP=1                # 1 = try direct MCP first for reads AND writes (0 = always use the relay)
RH_DIRECT_TIMEOUT_S=20         # per-call HTTP timeout for the direct MCP path

# --- Quote sourcing (market_conditions.py fetch chain) ---
# Free keyless CDNs first (Stooq -> Cboe -> Yahoo); a lone throttled symbol (e.g. null SPY) no longer
# stalls the gate (freshness keys off the NEWEST of SPY/QQQ/IWM/DIA). RH MCP is the authenticated
# fallback — now via the DIRECT HTTP path (rh_direct, ~0.3s, $0, no LLM), with the haiku relay only as
# the deepest last resort. Gated:
QUOTES_MCP_FALLBACK=auto       # auto = on in live only (paper never pays for quotes); 1 = force on; 0 = off
# The keyless race is DEADLINE-BOUNDED so a degraded Cboe (per-symbol 12s timeouts + 429 retries) can't
# hang the [3/5] context step for minutes (seen 2026-06-10: 216s). At the deadline the race returns its
# high-priority prefix (indexes/held/armed are fetched first) and RH-direct fills any gap.
QUOTES_DEADLINE_S=25           # max wall-clock for the keyless CDN race before falling to RH-direct
QUOTES_PREFER_RH=1             # 1 = RH-direct is the PRIMARY quote source (sub-second ticks, all symbols,
                               #   no dropped tail; loses Cboe's iv30 + session-open intraday_pct nuance).
                               #   0 = keyless CDNs first, RH-direct only as the deadline fallback.
QUOTES_LOG=1                   # 1 = log universe size + winning source + per-fetch timing to stderr

# --- Tick progress narration (paper + live; decide.py is shared) ---
# Each DD and broker-relay call is a 10-180s headless `claude` subprocess. These print a live
# "→ running… / ✓ done (Ns · tok · $)" bracket per call so a tick isn't minutes of silence.
TICK_PROGRESS=1                # 1 = narrate every call to stdout (run scripts tee it); 0 = silent
TICK_PROGRESS_HEARTBEAT_S=20   # while a long call runs, tick a "…still running (Ns)" line every N s (0=off)

# --- Order execution model ---
# Every BUY is a whole-share marketable limit + resting broker stop-market (GTC). If even 1 share
# exceeds MAX_POSITION_USD the entry is skipped rather than falling back to fractional.
# Paper models real marketable-limit slippage; fills past the limit cap are rejected.
SLIPPAGE_BPS=10                # adverse slippage per fill, basis points (10 = 0.10%)
MARKETABLE_LIMIT_PCT=0.5       # buy limit ceiling above the touch (price protection vs runaway print)

# --- Per-trade & daily loss controls ---
STOP_LOSS_PCT=12.0             # hard stop: 12% gives multi-day drift room (backtest optimum on large caps)
TAKE_PROFIT_PCT=40.0           # far full-exit target; time-exit / stop govern, TP rarely binds by design
# Trailing stop (LIVE only): ratchet the resting broker stop up toward the high-water mark, never down.
TRAIL_STOP_PCT=15              # trail 15% below the high-water mark once TRAIL_ACTIVATE_PCT is reached
TRAIL_ACTIVATE_PCT=20          # only start trailing once up +20%; below this the hard stop stands
TRAIL_BREAKEVEN_AT_PCT=0       # 0 = OFF. >0 lifts stop to entry (breakeven) once up this %.
TRAIL_MIN_STEP_PCT=0.5         # churn guard: skip a re-arm whose raise is < this % of the current stop
MAX_PER_TRADE_LOSS_PCT=0.02    # max $ at risk if the stop fills = 2% of equity (bounds notional×stop%)
DAILY_MAX_LOSS_PCT=0.05        # circuit breaker: halt new entries at 5% of start-of-day equity...
DAILY_MAX_LOSS_CAP_USD=500     # ...but never more than this absolute $/day (cap overtakes % above $10k equity)
# Cumulative-loss tripwire: if live equity falls LIVE_TRIPWIRE_PCT below the baseline,
# live_execute halts NEW entries (exits/stops keep running) until the owner reviews.
# Never resets overnight (unlike the daily breaker). 0 = off.
LIVE_TRIPWIRE_BASELINE_USD=0   # set to live-start equity when arming
LIVE_TRIPWIRE_PCT=10           # halt at this cumulative % drawdown from baseline

# --- Scale-out ladder ("gain%:fractionOfEntryQty" pairs; empty = OFF) ---
# OFF for catalyst-drift: trimming early cut the multi-day drift in the backtest.
SCALE_OUT_TIERS=
SCALE_BREAKEVEN_AFTER_FIRST=1  # (only relevant if SCALE_OUT_TIERS is set)

# --- Holding risk monitor ---
# Tier-1: cheap per-tick protective sell of a deteriorating loser.
HOLD_RISK_SELL=1               # 1 = enable Tier-1 protective sell; 0 = score only. Backtested 2026-06-09
                               #   (backtest_exit_policy): ONLY the deep 8% soft-cut earns its keep.
SOFT_CUT_PCT=8.0               # protective-sell a falling loser at this % underwater (8 = backtested optimum;
                               #   4 was strictly worse than no soft-cut at all)
HOLD_RISK_CRIT_SELL=0          # critical-band auto-sell off (fails the mean+sharpe bar); band still drives re-DD
# Tier-2: risk-adaptive agent manage-DD — re-check each holding's thesis on fresh news.
HOLD_REVIEW_MAX_PER_TICK=2     # max holdings re-checked per tick (riskiest first)
HOLD_REDD_TTL_CRIT_MIN=0       # critical band -> re-DD every tick
HOLD_REDD_TTL_HIGH_MIN=15      # high   -> re-DD every ~15 min
HOLD_REDD_TTL_MED_MIN=45       # medium -> every ~45 min
HOLD_REDD_TTL_LOW_MIN=120      # low    -> every ~120 min

# --- Entry signal: FREE REIN (no mechanical gate — the agent picks) ---
# tick_context.py hands the agent the day's movers and the agent decides with full discretion.
# The knobs below are DEPRECATED; kept so old tooling and logs don't break.
GAP_THRESHOLD_PCT=7.0          # RE-PURPOSED: PEAD labeling bar (pead_qualified = gap >= this on
                               #   rel_volume >= VOL_MULT_MIN); not an entry gate
VOL_MULT_MIN=2.0               # volume leg of the pead_qualified labeling bar
SIGNAL_THRESHOLD_PCT=3.0       # DEPRECATED
REL_STRENGTH_PCT=3.0           # DEPRECATED

# --- Two-book split (strategies/two-book-v2-plan.md): pead (measured edge) vs disco (free rein) ---
BOOKS_ENABLED=0                # 0 = tagging only (Phase 0); 1 = enforce ceiling/priority/ownership
BOOK_PEAD_MAX_FRAC=0.30        # pead exposure CEILING (fraction of live equity) — NOT a reserve
PEAD_BOOK_MIN_MKTCAP_USD=30000000000  # $30B proxy for the backtested mega-cap LARGE universe
BOOK_PEAD_ENABLED=1            # per-book disarm: 0 halts that book's NEW entries only
BOOK_DISCO_ENABLED=1
BOOK_TRIPWIRE_PCT=10           # book halts at -this% cum. net P&L of its ceiling share of baseline
PEAD_DIRECTION=up              # drop fresh negative-gap earnings reporters pre-DD ("any" disables)
PEAD_SEASON_RESERVE_PCT=0      # optional earnings-season settled-cash reserve (not built yet)

# --- Holding horizon: MULTI-DAY drift ---
MAX_HOLD_DAYS=21               # time-exit after N calendar days (~15 trading days = the drift window)
MAX_HOLD_MIN=0                 # OFF: no intraday recycle — hold the drift out
FLATTEN_BEFORE_CLOSE_MIN=0     # OFF: do not flatten at the close — hold overnight (edge is overnight)
NO_ENTRY_LAST_MIN=0            # OFF: entering near the close is fine for a multi-day hold
WINDDOWN_BEFORE_CLOSE_MIN=0    # OFF: no EOD green-lock
WINDDOWN_MIN_PROFIT_PCT=1.0    # (only relevant if WINDDOWN_BEFORE_CLOSE_MIN > 0)
COOLDOWN_MIN=1440              # no re-entry into a name within N min (=1 day) of exiting it
STALL_BAND_PCT=2.0             # (only relevant if MAX_HOLD_MIN > 0)

# --- Tick engine ---
PAPER_START_CASH=3000          # starting paper cash (mirrors the planned funding)
ALLOW_OFFHOURS=0               # 1 = let ticks run when market is closed (testing only)
DD_MODEL=claude-sonnet-4-6              # entry DD model (Sonnet + web research)
DD_MODEL_MANAGE=claude-haiku-4-5-20251001  # manage-DD model (lighter; keep/trim/exit is simpler than entry)
MAX_DD_CANDIDATES=10                    # max names evaluated per tick
DD_MAX_PARALLEL=6                       # concurrent DD agents (>6 on one Mac contend on web I/O -> slower)
DD_CLAUDE_TIMEOUT_S=300                 # per-DD wall-clock cap
# --- Async DD (decouple DD latency from the tick) ---
DD_ASYNC=1                              # 1 = entry DDs run in detached background workers (dd_worker.py);
                                        #   verdicts land next tick. 0 = inline/blocking (default safe).
DD_ASYNC_MAX_INFLIGHT=5                 # ceiling on concurrent background DD workers
DD_ASYNC_RUNNING_TIMEOUT_S=600         # a 'running' job older than this => worker died; reap + re-dispatch
DD_CACHE_INDEFINITE=1                   # 1 = reuse a DD verdict ACROSS days, expiring ONLY on the price-
                                        #   movement trigger below (no calendar expiry); 0 = once-per-ET-day
DD_CACHE_TTL_MIN=0                      # 0 = no rolling-age cap; drift % is the re-DD trigger
DD_REJECT_TTL_MIN=20                    # reuse a REJECT verdict for N min
DD_CACHE_DRIFT_PCT=5.0                  # re-DD a cached verdict if price moved > this % since the DD
STOCK_MEMORY_ENABLED=1                  # long-term per-symbol eval memory + never-buy exclusions
                                        #   (data/stock_memory.json). 0 = off. Manage via:
                                        #   python3 scripts/stock_memory.py [show SYM | exclude SYM "why" | allow SYM]

# --- Dynamic discovery (keyless Nasdaq screener) ---
# The engine trades only what the market is moving — no fixed watchlist. Discovery pulls today's
# top gainers and applies an eligibility filter (price, mcap, dollar-volume, IPO recency).
DISCOVERY_ENABLED=1            # 1 = pull today's top movers live; 0 = disabled
MAX_DISCOVERY_CANDIDATES=25    # how many top eligible gainers to surface per tick
MIN_PRICE=8                    # skip sub-$N names (a stop dies on penny stocks)
MIN_MARKET_CAP_USD=300000000   # $300M+ floor: admit small/mid-cap catalyst names...
MIN_DOLLAR_VOL=20000000        # ...but keep a $20M/day $-volume floor so positions stay exitable
EXCLUDE_RECENT_IPO=0           # 1 = drop names that IPO'd this calendar year
DISCOVERY_CACHE_MIN=5          # reuse the movers snapshot for N min
NON_TRADABLE_SYMBOLS=          # extra symbols to never buy (index ETFs already excluded)
# CANDIDATES = emergency fallback ONLY — used when discovery fails entirely (rate-limit/network error).
# Normally empty: the engine trades only what the market is moving, not a fixed watchlist.
CANDIDATES=

# --- Optional market-data API ---
MARKET_DATA_API_KEY=
