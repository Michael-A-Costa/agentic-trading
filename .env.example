# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Account ---
AGENTIC_ACCOUNT=your_account_number      # the only agentic_allowed account; trade nothing else

# --- Execution mode ---
# paper = simulate against live quotes, place nothing.
# live  = autonomous real orders via the MCP, no per-trade approval (caps below are the gate).
TRADING_MODE=paper

# --- Risk guardrails (the real safety layer; tune for the funded balance) ---
# Defaults assume a ~$3,000 funded account. Adjust once the deposit lands.
MAX_POSITION_USD=300           # max notional per single position (~10% of $3k)
MAX_TOTAL_EXPOSURE_USD=2400    # max invested at once (~80%), keep a cash buffer
MAX_SYMBOL_WEIGHT=0.25         # max fraction of portfolio in one symbol
MAX_OPEN_POSITIONS=6           # diversification cap

# --- Per-trade & daily loss controls ---
STOP_LOSS_PCT=2.0              # hard stop per position
TAKE_PROFIT_PCT=4.0            # target per position
MAX_PER_TRADE_LOSS_USD=60      # absolute stop-loss budget per trade
DAILY_MAX_LOSS_USD=150         # circuit breaker: halt new entries for the day if breached

# --- Signal (must clear the spread; see strategies/) ---
SIGNAL_THRESHOLD_PCT=2.0       # entry trigger; keep >= ~2x typical spread

# --- Tick engine (scripts/run_trading_tick.sh) ---
PAPER_START_CASH=3000          # starting paper cash (mirrors the planned funding)
ALLOW_OFFHOURS=0               # 1 = let ticks run when market is closed (testing only)
SCREEN_MODEL=claude-haiku-4-5-20251001   # Stage-1 screen (cheap, every tick)
DD_MODEL=claude-opus-4-8                # Stage-2 commit DD (Opus + web news, rare)
MAX_DD_CANDIDATES=2                     # max names deep-DD per tick
CANDIDATES=AAPL,NVDA,TSLA,AMD,MSFT,AMZN,META,GOOGL,SPY,QQQ,F,PLTR  # discovery universe

# --- Optional market-data API (if a strategy pulls external data) ---
MARKET_DATA_API_KEY=
