# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Risk limits (consumed by strategies; tune to taste) ---
MAX_POSITION_USD=1000          # max notional per single position
MAX_PER_TRADE_LOSS_USD=100     # stop-loss budget per trade
MAX_TOTAL_EXPOSURE_USD=5000    # max total invested across positions
MAX_SYMBOL_WEIGHT=0.20         # max fraction of portfolio in one symbol

# --- Execution mode ---
TRADING_MODE=paper             # paper | live  (live places real orders via the MCP)

# --- Optional market-data API (if a strategy pulls external data) ---
MARKET_DATA_API_KEY=
