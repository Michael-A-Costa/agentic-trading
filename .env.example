# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Account ---
AGENTIC_ACCOUNT=your_account_number      # the only agentic_allowed account; trade nothing else

# --- Execution mode ---
# paper = simulate against live quotes, place nothing.
# live  = autonomous real orders via the MCP, no per-trade approval (caps below are the gate).
TRADING_MODE=paper

# --- Risk guardrails (the real safety layer; tune for the funded balance) ---
# Defaults assume a ~$3,000 funded account. Adjust once the deposit lands.
# ALL of these are enforced deterministically in apply_decision.py / tick_context.py.
MAX_POSITION_USD=600           # max notional per single position (~20% of $3k)
MAX_TOTAL_EXPOSURE_USD=2400    # max invested at once (~80%), keep a cash buffer
MAX_SYMBOL_WEIGHT=0.25         # max fraction of (live) equity in one symbol — enforced at fill
MAX_OPEN_POSITIONS=6           # diversification cap
MIN_POSITION_USD=0             # reject fills smaller than this (0 = no floor; e.g. 25 avoids dust)

# --- Per-trade & daily loss controls ---
STOP_LOSS_PCT=2.0              # hard stop per position
TAKE_PROFIT_PCT=4.0            # target per position
MAX_PER_TRADE_LOSS_USD=60      # max $ at risk if the stop fills (bounds SIZE: notional*STOP_LOSS_PCT)
DAILY_MAX_LOSS_USD=150         # circuit breaker: halt new entries for the day (re-checked at fill)

# --- Signal (must clear the spread; see strategies/) ---
SIGNAL_THRESHOLD_PCT=2.0       # absolute intraday entry trigger; keep >= ~2x typical spread
REL_STRENGTH_PCT=1.0           # ALSO require this much intraday % above SPY (don't just buy beta)

# --- Exit / re-entry timing (deterministic risk mgmt; minutes) ---
FLATTEN_BEFORE_CLOSE_MIN=15    # flatten ALL positions N min before the 16:00 ET close (0 = off)
NO_ENTRY_LAST_MIN=15           # block NEW entries in the last N min before close (0 = off)
COOLDOWN_MIN=30                # no re-entry into a name within N min of exiting it (anti-whipsaw)
MAX_HOLD_MIN=0                 # force-exit a position held longer than N min (0 = off)

# --- Tick engine (scripts/run_trading_tick.sh) ---
PAPER_START_CASH=3000          # starting paper cash (mirrors the planned funding)
ALLOW_OFFHOURS=0               # 1 = let ticks run when market is closed (testing only)
DD_MODEL=claude-sonnet-4-6              # Stage-2 commit DD (Sonnet + web news)
MAX_DD_CANDIDATES=2                     # max names deep-DD per tick
DD_CACHE_TTL_MIN=180                   # reuse a symbol's DD verdict for N min (60..1440; default 3h)
CANDIDATES=AAPL,NVDA,TSLA,AMD,MSFT,AMZN,META,GOOGL,SPY,QQQ,F,PLTR  # discovery universe

# --- Optional market-data API (if a strategy pulls external data) ---
MARKET_DATA_API_KEY=
