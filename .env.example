# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Account ---
AGENTIC_ACCOUNT=your_account_number      # the only agentic_allowed account; trade nothing else

# --- Execution mode ---
# paper = simulate against live quotes, place nothing (apply_decision.py).
# live  = real orders via the MCP relay (live_execute.py): marketable-limit entries + resting
#         stop-market exits, no per-trade approval — the .env caps + review + dry-run gate are the
#         seatbelt. Python can't call the MCP, so orders go through a tightly-scoped headless agent.
TRADING_MODE=paper
# Two-step arming so live can't fire by accident. With TRADING_MODE=live but LIVE_ARMED!=1 the engine
# does everything INCLUDING review_equity_order (real broker quotes/alerts) but only LOGS the orders
# it would place — a true dry-run. Set LIVE_ARMED=1 to actually place. First armed order is capped to
# a tiny canary until one live round-trip completes.
LIVE_ARMED=0
LIVE_CANARY_USD=20             # first real order is capped to this $ until a round-trip succeeds
RH_EXEC_MODEL=claude-sonnet-4-6  # model for the MCP relay agent (mechanical tool-calling + strict JSON)
RH_EXEC_TIMEOUT_S=180          # per relay-agent wall-clock cap

# --- Risk guardrails (the real safety layer; tune for the funded balance) ---
# Defaults assume a ~$3,000 funded account. Adjust once the deposit lands.
# ALL of these are enforced deterministically in apply_decision.py / tick_context.py.
# Caps are a FRACTION OF EQUITY — tick_context.py resolves them to $ each tick (caps.*_USD), so they
# auto-scale with the account instead of freezing at the funding balance. Sizing + per-trade loss use
# LIVE equity; the daily breaker uses START-OF-DAY equity and is capped at an absolute $/day. The only
# remaining hard $ are MIN_POSITION_USD (dust floor) and DAILY_MAX_LOSS_CAP_USD (the breaker ceiling).
# CATALYST-DRIFT v1 = the owner's RISKY sleeve -> CONCENTRATED (few, large bets). See
# strategies/catalyst-drift-v1-plan.md and research/signal-backtests.md.
MAX_POSITION_PCT=0.15          # per-name ceiling = 15% of equity. Concentrated risk-on sizing.
MAX_TOTAL_EXPOSURE_PCT=0.90    # up to 90% invested — a risky directional book runs hot.
MAX_OPEN_POSITIONS=30          # up to 30 names. NOTE: at MAX_POSITION_PCT=0.15 + 0.90 exposure the
                               #   EXPOSURE cap binds ~6 names first — lower MAX_POSITION_PCT to fill more slots.
MIN_POSITION_USD=0             # reject fills smaller than this (0 = no floor; e.g. 25 avoids dust)

# --- Order execution model (how fills are priced — limit protection + honest slippage) ---
# Paper models a real MARKETABLE order, not a free fill at the last print: buys pay up / sells give
# up SLIPPAGE_BPS of the quote, and every BUY carries a limit capped MARKETABLE_LIMIT_PCT above the
# touch (a fill modeled past that cap is skipped — the live executor will reuse this exact rule).
SLIPPAGE_BPS=10                # adverse slippage per fill, basis points (10 = 0.10%); raise for thinner names
MARKETABLE_LIMIT_PCT=0.5       # buy limit ceiling above the touch (price protection vs a runaway print)
PREFER_WHOLE_SHARES=1          # 1 = floor buys to whole shares so the lot can carry a REAL resting
                               #   stop-market in live (fractional = broker market-only -> synthetic
                               #   engine stop). Falls back to fractional when <1 share is affordable.
                               #   0 = pure fractional dollar sizing (all stops synthetic).

# --- Per-trade & daily loss controls (now % of equity, like the sizing caps) ---
STOP_LOSS_PCT=8.0              # WIDER hard stop: high-beta names held multi-day need room (backtest used 8%).
TAKE_PROFIT_PCT=25.0           # FAR full-exit target: let the multi-day drift run; time-exit/stop govern, not an early TP.
MAX_PER_TRADE_LOSS_PCT=0.02    # max $ at risk if the stop fills = 2% of equity (bounds notional*STOP_LOSS_PCT).
                               #   At an 8% stop this implies ~25% of equity in notional — above the 15% position
                               #   cap, so it stays a SLACK backstop (raised in step with the wider stop).
DAILY_MAX_LOSS_PCT=0.05        # circuit breaker: halt new entries for the day at 5% of START-OF-DAY
                               #   equity (resolved to $ each tick, re-checked at fill; scales w/ account)...
DAILY_MAX_LOSS_CAP_USD=500     # ...but never risk more than this absolute $/day. The cap overtakes the
                               #   % once equity > $10k (5% of $10k = $500); below that the % governs.

# --- Holding risk monitor (Tier-1): cheap per-tick protective sell of a DETERIORATING loser ---
# Smarter than the hard STOP_LOSS_PCT stop (which stays the catastrophe backstop): cuts a loser past
# SOFT_CUT_PCT *only when it's still falling* and not a high-conviction runner, so it doesn't whipsaw a
# noisy-but-fine name. Ranks every holding by risk (hold_risk.py) and drives the Tier-2 re-DD cadence.
HOLD_RISK_SELL=1               # 1 = enable the Tier-1 protective sell; 0 = score only (no auto-sell)
SOFT_CUT_PCT=4.0              # protective-sell a loser this % underwater *when it's still falling*
# Tier-2: risk-adaptive agent manage-DD — re-check each holding's THESIS on fresh news, but ONLY when
# its risk-band re-DD TTL has elapsed (riskier = sooner), capped per tick. Verdict: keep/trim/exit/add.
HOLD_REVIEW_MAX_PER_TICK=4     # max holdings the agent re-checks per tick (cost cap; riskiest first)
HOLD_REDD_TTL_CRIT_MIN=0       # critical band -> re-DD now / every tick
HOLD_REDD_TTL_HIGH_MIN=5       # high   -> re-DD every ~5 min
HOLD_REDD_TTL_MED_MIN=20       # medium -> every ~20 min
HOLD_REDD_TTL_LOW_MIN=60       # low (calm/working) -> every ~60 min

# --- Scale-out ladder ("gain%:fractionOfEntryQty" pairs; empty = OFF) ---
# OFF for catalyst-drift: trimming early cut the multi-day drift in the backtest — let winners run.
SCALE_OUT_TIERS=
SCALE_BREAKEVEN_AFTER_FIRST=1  # (only relevant if SCALE_OUT_TIERS is set) ratchet stop to entry after first trim.

# --- Entry signal: FREE REIN (no mechanical gate — the AGENT picks) ---
# The risky/fun sleeve. tick_context.py applies NO entry signal — it hands the agent the day's tradable
# movers + the always-watch pins, and the agent (dd_prompt.txt) decides what's worth a shot and the hold
# horizon (scalp/swing/runner), with stops + caps + the daily breaker as the only seatbelts. The knobs
# below are DEPRECATED / unused by the gate; kept so old tooling and logs don't break.
GAP_THRESHOLD_PCT=7.0          # DEPRECATED (free-rein: no gap gate)
VOL_MULT_MIN=2.0              # DEPRECATED (free-rein: no volume gate)
SIGNAL_THRESHOLD_PCT=3.0       # DEPRECATED (old intraday-pop trigger)
REL_STRENGTH_PCT=3.0           # DEPRECATED (old rel-strength bar)

# --- Holding horizon: MULTI-DAY drift (NOT intraday) ---
MAX_HOLD_DAYS=21               # time-exit after N CALENDAR days (~15 trading days = the drift window). The core exit.
MAX_HOLD_MIN=0                 # OFF: no intraday recycle — hold the drift out.
FLATTEN_BEFORE_CLOSE_MIN=0     # OFF: do NOT flatten at the close — hold overnight (the edge is overnight).
NO_ENTRY_LAST_MIN=0            # OFF: entering near the close is fine for a multi-day hold (backtest entered at close).
WINDDOWN_BEFORE_CLOSE_MIN=0    # OFF: no EOD green-lock — let the drift run overnight.
WINDDOWN_MIN_PROFIT_PCT=1.0    # (only relevant if WINDDOWN_BEFORE_CLOSE_MIN > 0)
COOLDOWN_MIN=1440              # no re-entry into a name within N min (=1 day) of exiting it (anti-whipsaw on a stop-out)
STALL_BAND_PCT=2.0             # (only relevant if MAX_HOLD_MIN > 0)

# --- Tick engine (scripts/run_trading_tick.sh) ---
PAPER_START_CASH=3000          # starting paper cash (mirrors the planned funding)
ALLOW_OFFHOURS=0               # 1 = let ticks run when market is closed (testing only)
DD_MODEL=claude-sonnet-4-6              # Stage-2 commit DD (Sonnet + web news)
MAX_DD_CANDIDATES=10                    # max names the agent evaluates per tick (free-rein: more shots; each ~85s Sonnet+web)
DD_MAX_PARALLEL=10                      # run ALL candidates concurrently — one headless agent each (heavy CPU/net load)
DD_CACHE_TTL_MIN=30                     # reuse a COMMIT verdict for N min
DD_REJECT_TTL_MIN=20                    # reuse a REJECT for N min (0 = re-DD every tick; caps cost when
                                        #   discovery keeps surfacing the same movers)
DD_CACHE_DRIFT_PCT=3.0                  # re-DD a cached verdict (even inside its TTL) if the price moved
                                        #   > this % since the DD — fresh thesis when the setup changed
STOCK_MEMORY_ENABLED=1                  # long-term per-symbol eval memory that PRIMES each DD with our
                                        #   past verdicts + a permanent never-buy exclusion list
                                        #   (data/stock_memory.json). 0 = off. Manage via:
                                        #   python3 scripts/stock_memory.py [show SYM | exclude SYM "why" | allow SYM]

# --- Dynamic discovery (keyless Nasdaq screener; replaces a static stock allowlist) ---
# The engine must see what's actually moving/gapping market-wide, not a fixed watchlist. Discovery
# pulls today's top gainers and applies a rules-based ELIGIBILITY FILTER. For catalyst-drift the mcap
# floor is LOWERED to admit small/mid-cap catalyst names (the risky mandate), but the $-volume floor
# is KEPT so a multi-day position stays exitable — liquidity is the hard limit. See scripts/discover.py.
DISCOVERY_ENABLED=1            # 1 = pull today's top movers live; 0 = use CANDIDATES pins only
MAX_DISCOVERY_CANDIDATES=25    # how many top eligible gainers to surface per tick
MIN_PRICE=5                    # skip sub-$N names (a stop dies on penny stocks)
MIN_MARKET_CAP_USD=300000000   # $300M+ floor (was $2B): admit small/mid-cap catalyst names...
MIN_DOLLAR_VOL=20000000        # ...but KEEP a $20M/day $-volume floor so a multi-day position stays exitable
EXCLUDE_RECENT_IPO=1           # 1 = drop names that IPO'd this calendar year (too green)
DISCOVERY_CACHE_MIN=5          # reuse the movers snapshot for N min (screener refreshes every few min)
NON_TRADABLE_SYMBOLS=          # extra symbols to never buy (index ETFs already excluded)
# CANDIDATES = always-watch pins: a liquid high-beta MENU the agent can take a shot on even on a quiet
# day (in addition to discovery's live movers). Also the fallback if discovery is off/down.
CANDIDATES=AAPL,NVDA,TSLA,AMD,MSFT,AMZN,META,GOOGL,PLTR,COIN,HOOD,SOFI,MARA,RIOT,MSTR,SMCI,AVGO,NFLX,RIVN,NIO

# --- Optional market-data API (if a strategy pulls external data) ---
MARKET_DATA_API_KEY=
