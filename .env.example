# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Account ---
AGENTIC_ACCOUNT=your_account_number      # the only agentic_allowed account; trade nothing else

# --- Execution mode ---
# paper = simulate against live quotes, place nothing.
# live  = autonomous real orders via the MCP, no per-trade approval (caps below are the gate).
TRADING_MODE=paper

# --- Risk guardrails (the real safety layer; tune for the funded balance) ---
# Defaults assume a ~$3,000 funded account. Adjust once the deposit lands.
# ALL of these are enforced deterministically in apply_decision.py / tick_context.py.
# Caps are a FRACTION OF EQUITY — tick_context.py resolves them to $ each tick (caps.*_USD), so they
# auto-scale with the account instead of freezing at the funding balance. Sizing + per-trade loss use
# LIVE equity; the daily breaker uses START-OF-DAY equity and is capped at an absolute $/day. The only
# remaining hard $ are MIN_POSITION_USD (dust floor) and DAILY_MAX_LOSS_CAP_USD (the breaker ceiling).
MAX_POSITION_PCT=0.10          # per-name ceiling = 10% of equity (~$300 at $3k). SINGLE concentration
                               #   cap — replaced MAX_SYMBOL_WEIGHT (same formula once sizing is a %).
MAX_TOTAL_EXPOSURE_PCT=0.80    # max invested at once = 80% of equity (~$2.4k at $3k); 20% cash buffer
MAX_OPEN_POSITIONS=10          # diversify across movers; need ≥8 to reach the 80% exposure cap at the
                               #   10% per-name size, so 10 = fully investable with slack, ~8% even weight
MIN_POSITION_USD=0             # reject fills smaller than this (0 = no floor; e.g. 25 avoids dust)

# --- Per-trade & daily loss controls (now % of equity, like the sizing caps) ---
STOP_LOSS_PCT=4.0              # hard stop per position — tighter than before; cut losers faster
TAKE_PROFIT_PCT=12.0           # FULL-exit target per position (~1:3 R:R at the 4% stop; let momentum run)
MAX_PER_TRADE_LOSS_PCT=0.01    # max $ at risk per trade if the stop fills = 1% of equity (bounds
                               #   notional*STOP_LOSS_PCT). At a 4% stop this implies ~25% of equity in
                               #   notional — above the 10% position cap, so it's a slack backstop. =$30 at $3k.
DAILY_MAX_LOSS_PCT=0.05        # circuit breaker: halt new entries for the day at 5% of START-OF-DAY
                               #   equity (resolved to $ each tick, re-checked at fill; scales w/ account)...
DAILY_MAX_LOSS_CAP_USD=500     # ...but never risk more than this absolute $/day. The cap overtakes the
                               #   % once equity > $10k (5% of $10k = $500); below that the % governs.

# --- Scale-out ladder (partial profit-taking on the way up; harvests wins the full TP rarely reaches) ---
# "gain%:fractionOfEntryQty" pairs. Below: at +5% sell a third, at +8% sell another third, let the
# last third ride to TAKE_PROFIT_PCT. Fractions are of the ENTRY qty, so it's exact thirds. Empty = off
# (hold full size to one all-or-nothing trigger). Tiers >= TAKE_PROFIT_PCT never fire (TP closes first).
SCALE_OUT_TIERS=5:0.33,8:0.33
SCALE_BREAKEVEN_AFTER_FIRST=1  # after the first trim, ratchet the synthetic stop up to entry (0 = leave it)

# --- Signal (discovery pre-filters to top gainers, so these add selectivity, not the main filter) ---
SIGNAL_THRESHOLD_PCT=3.0       # absolute intraday entry trigger (vs open) — require continuation
REL_STRENGTH_PCT=3.0           # ALSO require this much intraday % above SPY (name-specific, not beta)

# --- Exit / re-entry timing (deterministic risk mgmt; minutes) ---
FLATTEN_BEFORE_CLOSE_MIN=15    # flatten ALL positions N min before the 16:00 ET close (0 = off)
WINDDOWN_BEFORE_CLOSE_MIN=30   # in the last N min, lock in GREEN positions early (protect gains vs a choppy close);
                               #   set > FLATTEN_BEFORE_CLOSE_MIN or the hard flatten already covers it (0 = off)
WINDDOWN_MIN_PROFIT_PCT=1.0    # wind-down only sells positions with pnl% >= this (0 = any green; losers always wait for the hard flatten)
NO_ENTRY_LAST_MIN=15           # block NEW entries in the last N min before close (0 = off)
COOLDOWN_MIN=30                # no re-entry into a name within N min of exiting it (anti-whipsaw)
MAX_HOLD_MIN=120               # force-exit a STALLED position held longer than N min (recycle capital; 0 = off)
STALL_BAND_PCT=2.0             # max-hold only fires when |pnl%| < this (a runner/bleeder keeps its price rule; <=0 = blind time stop)

# --- Tick engine (scripts/run_trading_tick.sh) ---
PAPER_START_CASH=3000          # starting paper cash (mirrors the planned funding)
ALLOW_OFFHOURS=0               # 1 = let ticks run when market is closed (testing only)
DD_MODEL=claude-sonnet-4-6              # Stage-2 commit DD (Sonnet + web news)
MAX_DD_CANDIDATES=4                     # max names deep-DD per tick (each ~85s Sonnet+web — cost knob)
DD_CACHE_TTL_MIN=30                     # reuse a COMMIT verdict for N min
DD_REJECT_TTL_MIN=20                    # reuse a REJECT for N min (0 = re-DD every tick; caps cost when
                                        #   discovery keeps surfacing the same movers)
STOCK_MEMORY_ENABLED=1                  # long-term per-symbol eval memory that PRIMES each DD with our
                                        #   past verdicts + a permanent never-buy exclusion list
                                        #   (data/stock_memory.json). 0 = off. Manage via:
                                        #   python3 scripts/stock_memory.py [show SYM | exclude SYM "why" | allow SYM]

# --- Dynamic discovery (keyless Nasdaq screener; replaces a static stock allowlist) ---
# A momentum engine must see what's actually moving market-wide, not a fixed watchlist. Discovery
# pulls today's top gainers and applies a rules-based ELIGIBILITY FILTER (the real safety layer):
# price / market-cap / $-volume / IPO-age floors keep us in names a ~5-min synthetic stop can
# actually protect, while letting ANY qualifying name in. See scripts/discover.py.
DISCOVERY_ENABLED=1            # 1 = pull today's top movers live; 0 = use CANDIDATES pins only
MAX_DISCOVERY_CANDIDATES=25    # how many top eligible gainers to surface per tick
MIN_PRICE=5                    # skip sub-$N names (a synthetic stop dies on penny stocks)
MIN_MARKET_CAP_USD=2000000000  # $2B+ floor — liquidity, not a micro-cap pump
MIN_DOLLAR_VOL=20000000        # >= $N traded today — must be exitable
EXCLUDE_RECENT_IPO=1           # 1 = drop names that IPO'd this calendar year (too green)
DISCOVERY_CACHE_MIN=5          # reuse the movers snapshot for N min (screener refreshes every few min)
NON_TRADABLE_SYMBOLS=          # extra symbols to never buy (index ETFs already excluded)
# CANDIDATES = always-watch pins (screened every tick) + the fallback if discovery is off/down.
CANDIDATES=AAPL,NVDA,TSLA,AMD,MSFT,AMZN,META,GOOGL,F,PLTR

# --- Optional market-data API (if a strategy pulls external data) ---
MARKET_DATA_API_KEY=
